generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  platformPreferences PlatformPreference[]
  postHistories PostHistory[]
  galleryAssets GalleryAsset[]
  tokenAuditLogs TokenAuditLog[]
  preferredVideoFormat String @default("short")
  preferredAIStyle    String @default("Manual")

  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  accountName       String?
  isDistributionEnabled Boolean @default(true)
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenAuditLogs    TokenAuditLog[]

  @@unique([provider, providerAccountId])
}

model PlatformPreference {
  id         String  @id @default(cuid())
  userId     String
  platformId String
  isEnabled  Boolean @default(false)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platformId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PostHistory {
  id           String               @id @default(cuid())
  userId       String
  title        String
  description  String?
  videoFormat  String               @default("short")
  scheduledAt  DateTime?
  isPublished  Boolean              @default(false)
  stagedFileId String?
  createdAt    DateTime             @default(now())
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  platforms    PostPlatformResult[]
}

model PostPlatformResult {
  id             String      @id @default(cuid())
  postHistoryId  String
  platform       String
  accountName    String?
  accountId      String?
  platformPostId String?
  permalink      String?
  status         String      @default("success")
  errorMessage   String?
  resumableUrl   String?
  videoId        String?
  creationId     String?
  transcodeStatus String?    @default("skipped") // pending, processing, completed, failed, skipped
  optimizedFileId String?
  metadata       Json?
  lastOffset     Int         @default(0)
  progress       Int         @default(0)
  retryCount     Int         @default(0)
  lastRetryAt    DateTime?
  createdAt      DateTime    @default(now())
  postHistory    PostHistory  @relation(fields: [postHistoryId], references: [id], onDelete: Cascade)

  @@unique([postHistoryId, platform, accountId], name: "postHistoryId_platform_accountId")
}

model RoadmapTask {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  status      String   @default("pending") // pending, in-progress, completed
  priority    String   @default("High Priority") // Critical, High Priority, etc.
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([priority, status])
}

model LaunchTask {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  status      String   @default("pending") // pending, in-progress, completed
  category    String   @default("Marketing") // App Store, Marketing, Legal
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, status])
}

model GalleryAsset {
  id           String   @id @default(cuid())
  userId       String
  fileId       String   @unique // The UUID-based stagedFileId
  fileName     String
  fileSize     BigInt?
  mimeType     String?
  processingStatus String?  @default("ready") // ready, processing, failed
  metadata     Json?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TokenAuditLog {
  id        String   @id @default(cuid())
  userId    String
  accountId String?
  action    String   // ACCESS, REFRESH, REVOKE, etc.
  provider  String?
  reason    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([accountId])
  @@index([action])
  @@index([createdAt])
}
