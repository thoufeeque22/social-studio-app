generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

model Workspace {
  id                  String               @id @default(cuid())
  name                String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  members             WorkspaceMember[]
  accounts            Account[]
  postHistories       PostHistory[]
  galleryAssets       GalleryAsset[]
  metadataTemplates   MetadataTemplate[]
  platformPreferences PlatformPreference[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model User {
  id                   String               @id @default(cuid())
  name                 String?
  email                String?              @unique
  emailVerified        DateTime?
  image                String?
  preferredVideoFormat String               @default("short")
  preferredAIStyle     String               @default("Manual")
  accounts             Account[]
  galleryAssets        GalleryAsset[]
  metadataTemplates    MetadataTemplate[]
  platformPreferences  PlatformPreference[]
  postHistories        PostHistory[]
  sessions             Session[]
  tokenAuditLogs       TokenAuditLog[]
  workspaceMembers     WorkspaceMember[]
}

model MetadataTemplate {
  id          String     @id @default(cuid())
  userId      String
  workspaceId String?
  name        String
  content     String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
}

model Account {
  id                    String          @id @default(cuid())
  userId                String
  workspaceId           String?
  type                  String
  provider              String
  providerAccountId     String
  refresh_token         String?
  access_token          String?
  expires_at            Int?
  token_type            String?
  scope                 String?
  id_token              String?
  session_state         String?
  accountName           String?
  isDistributionEnabled Boolean         @default(true)
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace             Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tokenAuditLogs        TokenAuditLog[]

  @@unique([provider, providerAccountId])
  @@index([workspaceId])
}

model PlatformPreference {
  id          String     @id @default(cuid())
  userId      String
  workspaceId String?
  platformId  String
  isEnabled   Boolean    @default(false)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, platformId])
  @@index([workspaceId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PostHistory {
  id           String               @id @default(cuid())
  userId       String
  workspaceId  String?
  title        String
  description  String?
  videoFormat  String               @default("short")
  scheduledAt  DateTime?
  isPublished  Boolean              @default(false)
  stagedFileId String?
  createdAt    DateTime             @default(now())
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  platforms    PostPlatformResult[]

  @@index([workspaceId])
}

model PostPlatformResult {
  id              String      @id @default(cuid())
  postHistoryId   String
  platform        String
  accountName     String?
  accountId       String?
  platformPostId  String?
  permalink       String?
  status          String      @default("success")
  errorMessage    String?
  resumableUrl    String?
  videoId         String?
  creationId      String?
  lastOffset      Int         @default(0)
  retryCount      Int         @default(0)
  lastRetryAt     DateTime?
  createdAt       DateTime    @default(now())
  optimizedFileId String?
  transcodeStatus String?     @default("skipped")
  metadata        Json?
  progress        Int         @default(0)
  postHistory     PostHistory @relation(fields: [postHistoryId], references: [id], onDelete: Cascade)

  @@unique([postHistoryId, platform, accountId], name: "postHistoryId_platform_accountId")
}

model RoadmapTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  priority    String   @default("High Priority")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([priority, status])
}

model LaunchTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  category    String   @default("Marketing")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, status])
}

model GalleryAsset {
  id               String     @id @default(cuid())
  userId           String
  workspaceId      String?
  fileId           String     @unique
  fileName         String
  fileSize         BigInt?
  mimeType         String?
  expiresAt        DateTime
  createdAt        DateTime   @default(now())
  metadata         Json?
  processingStatus String?    @default("ready")
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace        Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([expiresAt])
}

model TokenAuditLog {
  id        String   @id @default(cuid())
  userId    String
  accountId String?
  action    String
  provider  String?
  reason    String?
  createdAt DateTime @default(now())
  account   Account? @relation(fields: [accountId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([action])
  @@index([createdAt])
}
